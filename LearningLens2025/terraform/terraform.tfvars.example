# AWS Region
aws_region = "us-east-1"

# Environment name
environment = "production"

# Project name for resource naming
project_name = "edulense"

# GitHub personal access token (create at https://github.com/settings/tokens)
# Requires:
#   - repo (full control of private repositories)
#   - repo:status
#   - repo_deployment
github_token = "ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# GitHub repository URL
github_repository = "https://github.com/rappleb1/2025_fall/"

# GitHub branch to deploy
github_branch = "team_e"

# Moodle service account credentials
# Create a service account in Moodle and generate an API token
moodle_username = "service_account"
moodle_password = "secure_password_here"

# Lambda function configuration
lambda_timeout = 30
lambda_memory  = 512

# CORS allowed origins (use ["*"] for development, restrict for production)
allowed_origins = ["*"]

# CloudWatch log retention
log_retention_days = 14

# Enable DynamoDB tables for faster data access
enable_dynamodb = true

# DynamoDB billing mode: "PAY_PER_REQUEST" (serverless) or "PROVISIONED" (fixed capacity)
dynamodb_billing_mode = "PAY_PER_REQUEST"

# Common tags for all resources
tags = {
  Project     = "EduLense"
  Team        = "SWEN670"
  Environment = "Production"
  ManagedBy   = "Terraform"
}
